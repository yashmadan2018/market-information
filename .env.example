# ─────────────────────────────────────────────
# Market Information — Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit your .env file to git.
# ─────────────────────────────────────────────

# ── Anthropic (Claude AI) ──────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── FRED (Federal Reserve Economic Data) ──────
# Free key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ── EIA (Energy Information Administration) ───
# Free key at: https://www.eia.gov/opendata/register.php
EIA_API_KEY=your_eia_api_key_here

# ── NewsAPI ───────────────────────────────────
# Free tier (100 req/day) at: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# ── New York Times API ────────────────────────
# Free key at: https://developer.nytimes.com/get-started
NYT_API_KEY=your_nyt_api_key_here

# ── Gmail SMTP (for email delivery) ───────────
# Use your Gmail address and an App Password (NOT your account password).
# Setup: https://myaccount.google.com/apppasswords
# Requires: Gmail 2-Step Verification enabled first.
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password_here
